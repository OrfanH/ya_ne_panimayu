      "gender": "masculine",
      "meaning": "cheerful / fun (masculine)",
      "exampleCyrillic": "Весёлая компания.",
      "exampleTransliteration": "Vesyolaya kompaniya.",
      "exampleMeaning": "A fun group."
    },
