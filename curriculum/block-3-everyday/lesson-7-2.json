        "grammarPoint": "nationality-adjective"
      },
      {
        "prompt": "What does весёлый mean?",
        "type": "text-input",
        "answer": "cheerful",
        "grammarPoint": "vocabulary"
      },
      {
        "prompt": "He is very tall: Он очень ___.",
        "type": "text-input",
        "answer": "высокий",
        "grammarPoint": "adjective-agreement-masculine"
      },
      {
        "prompt": "очень (very) changes form for gender.",
        "type": "multiple-choice",
        "options": ["True", "False — it is invariable"],
        "answer": "False — it is invariable",
        "grammarPoint": "adverb-invariable"
      }
    ]
  }
}
