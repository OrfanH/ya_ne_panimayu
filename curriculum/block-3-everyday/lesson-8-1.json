  "phases": {
    "hook": {
      "text": "Days of the week appear in nearly every practical sentence about planning, scheduling, and explaining your life. They also happen to be a useful case drill: 'on Monday' requires accusative (в + accusative for specific days). Seven words with a consistent case pattern."
    },
    "why": {
      "text": "Days of the week in Russian are used with в + accusative to express 'on [day]'. This mirrors the direction/movement accusative you learned in Unit 5 — here applied to time rather than place. The same preposition в covers both spatial and temporal contexts."
    },
    "explain": {
      "cards": [
        {
          "title": "The seven days",
          "body": "All days of the week are masculine in Russian except среда (Wednesday — feminine), пятница (Friday — feminine), суббота (Saturday — feminine), and воскресенье (Sunday — neuter). Write them in lowercase.",
          "examples": [
            { "cyrillic": "понедельник (м)", "transliteration": "ponedel'nik", "meaning": "Monday" },
            { "cyrillic": "вторник (м)", "transliteration": "vtornik", "meaning": "Tuesday" },
            { "cyrillic": "среда (ж)", "transliteration": "sreda", "meaning": "Wednesday" },
            { "cyrillic": "четверг (м)", "transliteration": "chetverg", "meaning": "Thursday" },
            { "cyrillic": "пятница (ж)", "transliteration": "pyatnitsa", "meaning": "Friday" },
            { "cyrillic": "суббота (ж)", "transliteration": "subbota", "meaning": "Saturday" },
            { "cyrillic": "воскресенье (ср)", "transliteration": "voskresen'ye", "meaning": "Sunday" }
          ]
        },
        {
          "title": "'On [day]' — в + accusative",
          "body": "To say an event happens on a specific day, use в + accusative of the day. Masculine days: no change (same as nominative for inanimate). Feminine days: А→У. Neuter воскресенье: no change (neuter accusative = nominative).",
          "examples": [
            { "cyrillic": "в понедельник", "transliteration": "v ponedel'nik", "meaning": "on Monday (masculine, no change)" },
            { "cyrillic": "в среду", "transliteration": "v sredu", "meaning": "on Wednesday (среда→среду, fem. acc.)" },
            { "cyrillic": "в пятницу", "transliteration": "v pyatnitsu", "meaning": "on Friday (пятница→пятницу, fem. acc.)" },
            { "cyrillic": "в субботу", "transliteration": "v subbotu", "meaning": "on Saturday (суббота→субботу, fem. acc.)" },
            { "cyrillic": "в воскресенье", "transliteration": "v voskresen'ye", "meaning": "on Sunday (neuter, no change)" }
          ]
        },
        {
          "title": "This week / last week / next week",
          "body": "Time expressions for week use на + this/that week in prepositional, or на следующей/прошлой неделе. эта неделя (this week) → на этой неделе (prepositional).",
          "examples": [
            { "cyrillic": "на этой неделе", "transliteration": "na etoy nedele", "meaning": "this week" },
            { "cyrillic": "на прошлой неделе", "transliteration": "na proshloy nedele", "meaning": "last week" },
            { "cyrillic": "на следующей неделе", "transliteration": "na sleduyushchey nedele", "meaning": "next week" }
          ]
        }
      ]
    },
    "midCheck": {
      "questions": [
        {
          "prompt": "How do you say 'on Wednesday'?",
          "type": "text-input",
          "answer": "в среду",
          "explanation": "среда → среду (feminine accusative: А→У). в среду."
        },
        {
          "prompt": "How do you say 'on Monday'?",
          "type": "text-input",
          "answer": "в понедельник",
          "explanation": "понедельник is masculine inanimate — accusative = nominative. в понедельник."
        },
        {
          "prompt": "How do you say 'this week'?",
          "type": "text-input",
          "answer": "на этой неделе",
          "explanation": "на + prepositional. эта неделя → этой неделе."
        }
      ]
    },
    "deepen": {
      "cards": [
        {
          "title": "Weekday vs weekend",
          "body": "будний день (weekday), будни (weekdays plural), выходной день (day off / weekend day). The word выходной (day off) is a common adjective-used-as-noun. суббота и воскресенье = the weekend.",
          "examples": [
            { "cyrillic": "В будни я работаю.", "transliteration": "V budni ya rabotayu.", "meaning": "On weekdays I work." },
            { "cyrillic": "В выходные я отдыхаю.", "transliteration": "V vikhodnyye ya otdykhayu.", "meaning": "On weekends I rest." }
          ]
        },
        {
          "title": "сегодня / завтра / вчера",
          "body": "The most practical time adverbs: сегодня (today), завтра (tomorrow), вчера (yesterday). They're invariable and never require a case change — just place before or after the main clause.",
          "examples": [
            { "cyrillic": "Сегодня понедельник.", "transliteration": "Segodnya ponedel'nik.", "meaning": "Today is Monday." },
            { "cyrillic": "Завтра вторник.", "transliteration": "Zavtra vtornik.", "meaning": "Tomorrow is Tuesday." },
            { "cyrillic": "Вчера была пятница.", "transliteration": "Vchera bila pyatnitsa.", "meaning": "Yesterday was Friday." }
          ]
        }
      ]
    },
    "drill": {
      "questions": [
        {
          "prompt": "What is 'on Friday'?",
          "type": "text-input",
          "answer": "в пятницу",
          "explanation": "пятница → пятницу (feminine: А→У). в пятницу."
        },
        {
          "prompt": "What day is today? Сегодня ___.",
          "type": "multiple-choice",
          "options": ["в понедельник", "понедельник", "в понедельнике"],
          "answer": "понедельник",
          "explanation": "сегодня [day] — just nominative. Сегодня понедельник. No preposition."
        },
        {
          "prompt": "How do you say 'on Thursday'?",
          "type": "text-input",
          "answer": "в четверг",
          "explanation": "четверг is masculine inanimate — accusative = nominative. в четверг."
        },
        {
          "prompt": "How do you say 'next week'?",
          "type": "text-input",
          "answer": "на следующей неделе",
          "explanation": "на + prepositional. следующая неделя → следующей неделе."
        },
        {
          "prompt": "What does неделя mean?",
          "type": "text-input",
          "answer": "week",
          "explanation": "неделя (nedelya) = week."
        },
        {
          "prompt": "What is 'on Saturday'?",
          "type": "text-input",
          "answer": "в субботу",
          "explanation": "суббота → субботу (feminine: А→У). в субботу."
        },
        {
          "prompt": "What does вчера mean?",
          "type": "text-input",
          "answer": "yesterday",
          "explanation": "вчера (vchera) = yesterday. Invariable."
        }
      ]
    },
    "summary": {
      "rules": [
        "'On [day]': в + accusative. Masculine days: no change. Feminine days: А→У. Neuter: no change.",
        "Days of the week are lowercase in Russian",
        "сегодня (today) / завтра (tomorrow) / вчера (yesterday) — invariable",
        "на этой неделе (this week) / на прошлой неделе (last week) / на следующей неделе (next week)"
      ],
      "vocabulary": ["понедельник", "вторник", "среда", "четверг", "пятница", "суббота", "воскресенье", "неделя"],
      "nextLesson": "Next: months and seasons — talking about dates and times of year."
    }
  },
