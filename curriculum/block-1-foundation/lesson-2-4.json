  "phases": {
    "hook": {
      "text": "Grammar is only useful when you have words to use it on. This lesson is a direct vocabulary investment — ten high-frequency nouns covering people, objects, and things you'll need from the very first real conversation. Every word here appears within the first five minutes of any practical interaction."
    },
    "why": {
      "text": "Russian nouns carry gender (masculine, feminine, neuter) and this gender affects everything — adjective endings, pronoun choice, verb agreement. Learning gender as part of the word from the start is far easier than learning it separately. Every noun entry here includes gender — treat it as inseparable from the word itself."
    },
    "explain": {
      "cards": [
        {
          "title": "Nouns and their gender",
          "body": "Every Russian noun is masculine, feminine, or neuter. You mostly can predict gender from the ending. Nouns ending in a consonant are usually masculine. Nouns ending in А/Я are usually feminine. Nouns ending in О/Е are usually neuter. Exceptions exist — learn them with the noun.",
          "examples": [
            { "cyrillic": "стол (consonant ending)", "transliteration": "stol", "meaning": "table — masculine" },
            { "cyrillic": "вода (А ending)", "transliteration": "voda", "meaning": "water — feminine" },
            { "cyrillic": "окно (О ending)", "transliteration": "okno", "meaning": "window — neuter" },
            { "cyrillic": "мужчина (А ending, exception)", "transliteration": "muzhchina", "meaning": "man — masculine despite А ending" }
          ]
        },
        {
          "title": "People vocabulary",
          "body": "Core people nouns — learn these with their gender. Note that мужчина ends in А but is masculine (biological gender overrides the ending rule for people words).",
          "examples": [
            { "cyrillic": "человек", "transliteration": "chelovek", "meaning": "person — masculine" },
            { "cyrillic": "мужчина", "transliteration": "muzhchina", "meaning": "man — masculine (ends in А but refers to males)" },
            { "cyrillic": "женщина", "transliteration": "zhenshchina", "meaning": "woman — feminine" },
            { "cyrillic": "друг", "transliteration": "drug", "meaning": "friend (male) — masculine" }
          ]
        },
        {
          "title": "Objects and essentials",
          "body": "High-frequency object nouns. These appear in the first lesson of almost any Russian course — they're the building blocks of sentences.",
          "examples": [
            { "cyrillic": "стол", "transliteration": "stol", "meaning": "table — masculine" },
            { "cyrillic": "стул", "transliteration": "stul", "meaning": "chair — masculine" },
            { "cyrillic": "окно", "transliteration": "okno", "meaning": "window — neuter" },
            { "cyrillic": "вода", "transliteration": "voda", "meaning": "water — feminine" },
            { "cyrillic": "еда", "transliteration": "yeda", "meaning": "food — feminine" },
            { "cyrillic": "деньги", "transliteration": "den'gi", "meaning": "money — always plural in Russian" }
          ]
        }
      ]
    },
    "midCheck": {
      "questions": [
        {
          "prompt": "What gender is стол?",
          "type": "multiple-choice",
          "options": ["masculine", "feminine", "neuter"],
          "answer": "masculine",
          "explanation": "стол ends in a consonant — masculine. The pattern: consonant ending = usually masculine."
        },
        {
          "prompt": "What does деньги mean?",
          "type": "text-input",
          "answer": "money",
          "explanation": "деньги (den'gi) = money. It's always plural in Russian — there's no singular form in everyday use."
        },
        {
          "prompt": "мужчина ends in А. What gender is it?",
          "type": "multiple-choice",
          "options": ["feminine", "masculine", "neuter"],
          "answer": "masculine",
          "explanation": "мужчина is masculine despite ending in А. For people, biological gender overrides the spelling rule."
        }
      ]
    },
    "deepen": {
      "cards": [
        {
          "title": "Это — this is / these are",
          "body": "Это (eto) is one of the most useful words in Russian. It means 'this is', 'that is', 'these are', 'those are' — it covers all of them. Crucially, это never changes form, regardless of what follows. Это книга, это стол, это деньги — always это.",
          "examples": [
            { "cyrillic": "Это стол.", "transliteration": "Eto stol.", "meaning": "This is a table." },
            { "cyrillic": "Это вода.", "transliteration": "Eto voda.", "meaning": "This is water." },
            { "cyrillic": "Это деньги.", "transliteration": "Eto den'gi.", "meaning": "This is money (these are)." }
          ]
        },
        {
          "title": "Russian has no articles",
          "body": "There is no 'a' or 'the' in Russian. стол means 'a table', 'the table', or just 'table' — context decides. Don't add an article when translating to Russian, and when translating from Russian, choose the article that fits the context.",
          "examples": [
            { "cyrillic": "Это стол.", "transliteration": "Eto stol.", "meaning": "This is a table. / This is the table." },
            { "cyrillic": "Где стол?", "transliteration": "Gde stol?", "meaning": "Where is the table?" }
          ]
        }
      ]
    },
    "drill": {
