        },
        {
          "prompt": "What does вода mean?",
          "type": "text-input",
          "answer": "water",
          "explanation": "вода (voda) = water. Feminine (ends in А)."
        },
        {
          "prompt": "How do you say 'this is a chair' in Russian?",
          "type": "text-input",
          "answer": "Это стул.",
          "explanation": "Это стул. (Eto stul.) = This is a chair. Это never changes form."
        },
        {
          "prompt": "What does друг mean?",
          "type": "text-input",
          "answer": "friend",
          "explanation": "друг (drug) = friend (male). Masculine."
        },
        {
          "prompt": "деньги is always used in which form?",
          "type": "multiple-choice",
          "options": ["singular", "plural", "both", "depends on the context"],
          "answer": "plural",
          "explanation": "деньги is always plural in Russian — there's no everyday singular form. Same pattern as English 'scissors' or 'trousers'."
        }
      ]
    },
    "summary": {
      "rules": [
        "Noun gender: consonant ending = usually masculine; А/Я ending = usually feminine; О/Е ending = usually neuter",
        "Exception: people words follow biological gender (мужчина is masculine despite А ending)",
        "Это = this is / that is / these are — never changes form",
        "Russian has no articles (a/the) — context determines which to use in translation",
        "деньги (money) is always plural"
      ],
      "vocabulary": ["человек", "мужчина", "женщина", "друг", "стол", "стул", "окно", "вода", "еда", "деньги"],
      "nextLesson": "Next: survival phrases — please, sorry, I don't understand, speak slowly — everything you need when language fails."
    }
