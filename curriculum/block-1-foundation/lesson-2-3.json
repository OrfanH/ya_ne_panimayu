  "phases": {
    "hook": {
      "text": "Numbers unlock a huge amount of practical Russian: prices, times, ages, addresses, dates. There are only 10 to learn today. The catch: the noun after a number changes form depending on the number. This lesson teaches the numbers first — the noun rules come later. Lock in the words now."
    },
    "why": {
      "text": "Russian numbers 1–4 and 5–20 follow different grammar rules for the nouns they govern — a notorious Russian difficulty. You'll meet this in detail in Unit 3. For now, see the numbers in example sentences and notice the noun endings changing, but don't stress about them yet. Your job today is to know один through десять cold."
    },
    "explain": {
      "cards": [
        {
          "title": "Numbers 1–5",
          "body": "Learn these as pure sound-shapes first, then attach meaning. Notice: один/одна/одно (one) has three gender forms. один for masculine, одна for feminine, одно for neuter. For now, default to один when speaking.",
          "examples": [
            { "cyrillic": "один / одна / одно", "transliteration": "odin / odna / odno", "meaning": "one (m / f / n)" },
            { "cyrillic": "два / две", "transliteration": "dva / dve", "meaning": "two (m-n / f)" },
            { "cyrillic": "три", "transliteration": "tri", "meaning": "three (all genders)" },
            { "cyrillic": "четыре", "transliteration": "chetyre", "meaning": "four (all genders)" },
            { "cyrillic": "пять", "transliteration": "pyat'", "meaning": "five — ends in Ь (soft sign)" }
          ]
        },
        {
          "title": "Numbers 6–10",
          "body": "Numbers 6–10 all end in Ь (soft sign). Say them as one unit — don't pause between the base and the soft sign. шесть, семь, восемь, девять, десять.",
          "examples": [
            { "cyrillic": "шесть", "transliteration": "shest'", "meaning": "six" },
            { "cyrillic": "семь", "transliteration": "sem'", "meaning": "seven" },
            { "cyrillic": "восемь", "transliteration": "vosem'", "meaning": "eight" },
            { "cyrillic": "девять", "transliteration": "devyat'", "meaning": "nine" },
            { "cyrillic": "десять", "transliteration": "desyat'", "meaning": "ten" }
          ]
        },
        {
          "title": "Noun form after numbers — preview",
          "body": "After 1: nominative singular (один дом — one house). After 2–4: genitive singular (два дома — two houses, literally 'two of house'). After 5–20: genitive plural (пять домов — five houses, 'five of houses'). You don't need to produce this correctly yet — just see the pattern in examples.",
          "examples": [
            { "cyrillic": "один дом", "transliteration": "odin dom", "meaning": "one house (nominative)" },
            { "cyrillic": "два дома", "transliteration": "dva doma", "meaning": "two houses (gen. singular)" },
            { "cyrillic": "пять домов", "transliteration": "pyat' domov", "meaning": "five houses (gen. plural)" }
          ]
        }
      ]
    },
    "midCheck": {
      "questions": [
        {
          "prompt": "What is the Russian word for 'seven'?",
          "type": "text-input",
          "answer": "семь",
          "explanation": "семь (sem') = seven. Ends with a soft sign Ь."
        },
        {
          "prompt": "которое из этих чисел — 'four'?",
          "type": "multiple-choice",
          "options": ["три", "четыре", "пять", "шесть"],
          "answer": "четыре",
          "explanation": "четыре (chetyre) = four."
        },
        {
          "prompt": "один has three gender forms. What are they?",
          "type": "multiple-choice",
          "options": [
            "один / одна / одно",
            "один / одни / одно",
            "один / одну / одно",
            "один / одна / одни"
          ],
          "answer": "один / одна / одно",
          "explanation": "один (m), одна (f), одно (n). The number 'one' agrees in gender with its noun."
        }
      ]
    },
    "deepen": {
      "cards": [
        {
          "title": "Counting vs using numbers",
          "body": "When counting aloud (один, два, три...), all genders default to the masculine form. But when saying 'one book' vs 'one house', the gender of the noun matters: одна книга (one book, feminine) vs один дом (one house, masculine). This only affects 1 and 2.",
          "examples": [
            { "cyrillic": "один урок", "transliteration": "odin urok", "meaning": "one lesson (masculine)" },
            { "cyrillic": "одна книга", "transliteration": "odna kniga", "meaning": "one book (feminine)" },
            { "cyrillic": "два урока", "transliteration": "dva uroka", "meaning": "two lessons (masculine/neuter)" },
            { "cyrillic": "две книги", "transliteration": "dve knigi", "meaning": "two books (feminine)" }
          ]
        },
        {
          "title": "Numbers in everyday contexts",
          "body": "You'll use numbers constantly for prices (сколько стоит? — how much does it cost?), time (сколько времени? — what time is it?), and age (сколько вам лет? — how old are you?). The word сколько (how many / how much) is worth noting now.",
          "examples": [
            { "cyrillic": "Мне двадцать лет.", "transliteration": "Mne dvadtsat' let.", "meaning": "I am twenty years old." },
            { "cyrillic": "Сколько стоит?", "transliteration": "Skolko stoit?", "meaning": "How much does it cost?" }
          ]
        }
      ]
    },
