        },
        {
          "prompt": "The masculine nominative adjective ending for hard-stem adjectives is:",
          "type": "multiple-choice",
          "options": ["-ой/-ый", "-ая", "-ое", "-ые"],
          "answer": "-ой/-ый",
          "explanation": "-ЫЙ for unstressed, -ОЙ for stressed endings. Both are masculine nominative."
