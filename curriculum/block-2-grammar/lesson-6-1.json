  "phases": {
    "hook": {
      "text": "Russian adjectives are not fixed — they change their endings to agree with the noun they describe. новый стол (new table), новая книга (new book), новое слово (new word). Same adjective, three different endings. This is agreement, and it applies to gender, number, and case. Today: gender and number in the nominative."
    },
    "why": {
      "text": "Adjective agreement is not optional — you can't leave an adjective in its dictionary form and attach it to any noun. The ending signals which noun it belongs to. Once you know the pattern (which is regular), you can apply it to any adjective you learn. The dictionary form is always masculine nominative — that's your starting point."
    },
    "explain": {
      "cards": [
        {
          "title": "Nominative adjective endings",
          "body": "Dictionary form = masculine nominative singular. To modify a feminine or neuter noun, change the ending. The 'hard' stem adjectives (most adjectives) follow this pattern: -ЫЙ/-ОЙ (m), -АЯ (f), -ОЕ (n), -ЫЕ (pl).",
          "examples": [
            { "cyrillic": "новый стол (m)", "transliteration": "noviy stol", "meaning": "new table (masculine)" },
            { "cyrillic": "новая книга (f)", "transliteration": "novaya kniga", "meaning": "new book (feminine)" },
            { "cyrillic": "новое слово (n)", "transliteration": "novoye slovo", "meaning": "new word (neuter)" },
            { "cyrillic": "новые столы (pl)", "transliteration": "noviye stoly", "meaning": "new tables (plural)" }
          ]
        },
        {
          "title": "Soft-stem adjectives",
          "body": "Some adjectives have a soft stem — the endings use Е instead of О: -ИЙ (m), -ЯЯ (f), -ЕЕ (n), -ИЕ (pl). хороший (good) and маленький (small) are the key examples.",
          "examples": [
            { "cyrillic": "хороший дом (m)", "transliteration": "khoroshiy dom", "meaning": "good house" },
            { "cyrillic": "хорошая школа (f)", "transliteration": "khoroshaya shkola", "meaning": "good school" },
            { "cyrillic": "хорошее слово (n)", "transliteration": "khorosheeye slovo", "meaning": "good word" },
            { "cyrillic": "хорошие дети (pl)", "transliteration": "khoroshiye deti", "meaning": "good children" }
          ]
        },
        {
          "title": "большой — the stress-shifted adjective",
          "body": "большой (big) looks like a feminine adjective form but it's masculine. This is because the stress falls on the ending (-ОЙ). This is a common pattern for stressed-ending adjectives: masculine -ОЙ, feminine -АЯ, neuter -ОЕ.",
          "examples": [
            { "cyrillic": "большой город (m)", "transliteration": "bolshoy gorod", "meaning": "big city" },
            { "cyrillic": "большая машина (f)", "transliteration": "bolshaya mashina", "meaning": "big car" },
            { "cyrillic": "большое море (n)", "transliteration": "bolshoye more", "meaning": "big sea" }
          ]
        }
      ]
    },
    "midCheck": {
      "questions": [
        {
          "prompt": "What is 'new book' (книга — feminine)?",
          "type": "text-input",
          "answer": "новая книга",
          "explanation": "новый → новая for feminine nouns. новая книга."
        },
        {
          "prompt": "What is 'good lesson' (урок — masculine)?",
          "type": "text-input",
          "answer": "хороший урок",
          "explanation": "хороший is already the masculine form. хороший урок."
        },
        {
          "prompt": "What is 'big city' (город — masculine)?",
          "type": "text-input",
          "answer": "большой город",
          "explanation": "большой is masculine. большой город."
        }
      ]
    },
    "deepen": {
      "cards": [
        {
          "title": "Spelling rules in adjective endings",
          "body": "The 7-letter spelling rule applies to adjective endings too. After Г К Х Ж Ш Щ Ч, write -ИЙ/-ИЕ, not -ЫЙ/-ЫЕ. This is why хороший ends in -ИЙ (Ш triggers the spelling rule).",
          "examples": [
            { "cyrillic": "хороший (not хорошый)", "transliteration": "khoroshiy", "meaning": "good — Ш triggers -ИЙ not -ЫЙ" },
            { "cyrillic": "маленький (not маленкый)", "transliteration": "malen'kiy", "meaning": "small — К triggers -ИЙ not -ЫЙ" }
          ]
        },
        {
          "title": "Possessive adjectives — мой/твой/наш/ваш",
          "body": "Possessives are adjectives and they agree in the same way. You already know мой/моя/моё/мои. наш/наша/наше/наши (our) and ваш/ваша/ваше/ваши (your formal/plural) follow the same pattern.",
          "examples": [
            { "cyrillic": "мой новый стол", "transliteration": "moy noviy stol", "meaning": "my new table (both agree: masculine)" },
            { "cyrillic": "моя новая книга", "transliteration": "moya novaya kniga", "meaning": "my new book (both agree: feminine)" },
            { "cyrillic": "наш большой город", "transliteration": "nash bolshoy gorod", "meaning": "our big city (both agree: masculine)" }
          ]
        }
      ]
    },
